{
  "name": "tmp_init",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "install": "echo \"Skipping node-gyp auto-build!\"",
    "start": "vite",
    "start:nw": "nw .",
    "nw": "npm run build:cpp && concurrently \"npm run dev:web\" \"npm run start:nw\"",
    "dev": "npm run build:cpp && npm run build:addon && concurrently \"npm run dev:web\" \"npm run dev:server\" \"npm run start:nw\"",
    "dev:web": "vite",
    "dev:server": "npm --prefix server run dev",
    "build:cpp": "node build_scripts/build-core.js",
    "build:addon": "node build_scripts/build-core-nodejs.js",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "main": "http://localhost:5173",
  "node-remote": "http://localhost:5173",
  "window": {
    "title": "RPG (Dev Mode)",
    "width": 1280,
    "height": 720
  },
  "nodejs": true,
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "node-addon-api": "^8.6.0",
    "primeicons": "^7.0.0",
    "primereact": "^10.9.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.27",
    "cmake-js": "^8.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "nw": "^0.109.0-sdk",
    "postcss": "^8.5.8",
    "sass": "^1.98.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0"
  }
}